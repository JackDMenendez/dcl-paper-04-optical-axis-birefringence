# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]

# external workspace folders (Windows symlinks to sibling repos)
.external/
external/
.scratchpad/

# Editor / IDE
.vscode/
.vs/
.idea/

# Build outputs
build/
stage/

# Per-machine Claude Code state
.claude/settings.json
.claude/settings.local.json

# LaTeX intermediates (the main PDF lives in build/, promoted to stage/)
*.aux
*.bbl
*.blg
*.log
!data/*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.fdb_latexmk_*
*.synctex.gz

# Python virtual environments (used by the full-stack template; harmless here)
.venv
.venv*
env/
venv/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# OS junk
.DS_Store
Thumbs.db
.vsisolation/

# Stray in-place LaTeX build artifacts (canonical build goes to build/ via make)
paper/*.pdf
paper/*.log
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.fls
paper/*.fdb_latexmk
